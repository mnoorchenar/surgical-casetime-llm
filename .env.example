# ============================================================
# API Keys — copy this file to .env and fill in your keys
#   cp .env.example .env
#
# Then load before running:
#   Windows CMD : set /p < .env  (or use python-dotenv)
#   Bash/Mac    : export $(cat .env | xargs)
# ============================================================

# Google Gemini — free at https://aistudio.google.com
# Used for: Stage 02 text embeddings (text-embedding-004, 768-d)
# Free quota: 1,500 requests/day
GEMINI_API_KEY=your_gemini_api_key_here

# Groq — free at https://console.groq.com
# Used for: Stage 02b LLM feature extraction (Llama-3.1-8b-instant)
# Free quota: 14,400 requests/day, 30 req/min
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace — no key needed (runs locally via sentence-transformers)
# Model: all-MiniLM-L6-v2 (384-d, ~90 MB, downloads automatically)
